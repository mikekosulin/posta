{{ define "content" }}
<h2 style="color: #111827; font-size: 20px; line-height: 1.3; margin: 0 0 18px; font-weight: 700; letter-spacing: -0.01em;">API {{ if eq .KeyCount 1 }}key{{ else }}keys{{ end }} expiring soon</h2>
<p style="margin: 0 0 16px;">Hi {{ .UserName }},</p>
<p class="lead" style="margin: 0 0 16px; font-size: 15px; color: #4b5563;">The following API {{ if eq .KeyCount 1 }}key is{{ else }}keys are{{ end }} in {{ if .WorkspaceName }}<strong>{{ .WorkspaceName }}</strong>{{ else }}your workspace{{ end }} expiring within the next 7 days.</p>

<table class="stats-table" role="presentation" style="width: 100%; border-collapse: separate; border-spacing: 0; margin: 20px 0; border: 1px solid #eceef2; border-radius: 10px; overflow: hidden;">
  <tr>
    <th style="padding: 12px 16px; text-align: left; border-bottom: 1px solid #eceef2; font-size: 14px; background-color: #f9fafb; color: #6b7280; font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em;">Key name</th>
    <th style="padding: 12px 16px; text-align: left; border-bottom: 1px solid #eceef2; font-size: 14px; background-color: #f9fafb; color: #6b7280; font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; text-align: right;">Expires</th>
  </tr>
  {{ range .Keys }}
  <tr>
    <td style="padding: 12px 16px; text-align: left; border-bottom: 1px solid #eceef2; font-size: 14px; color: #111827;"><strong>{{ .Name }}</strong></td>
    <td style="padding: 12px 16px; text-align: left; border-bottom: 1px solid #eceef2; font-size: 14px; color: #111827; text-align: right; color: #d97706;">{{ .ExpiresAt }}</td>
  </tr>
  {{ end }}
</table>

<div class="alert-box alert-warning" style="padding: 14px 16px; border-radius: 10px; margin: 20px 0; font-size: 14px; line-height: 1.55; background-color: #fffbeb; border: 1px solid #fde68a; color: #92400e;">
  Regenerate {{ if eq .KeyCount 1 }}this key{{ else }}these keys{{ end }} before {{ if eq .KeyCount 1 }}it expires{{ else }}they expire{{ end }} to avoid service interruption.
</div>

{{ if .AppURL }}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin: 28px auto;">
  <tr><td align="center" bgcolor="#7c3aed" style="border-radius: 8px;">
    <a href="{{ .AppURL }}/api-keys" class="btn" style="display: inline-block; padding: 13px 30px; background-color: #7c3aed; color: #ffffff !important; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 15px; line-height: 1;">Manage API keys</a>
  </td></tr>
</table>
{{ end }}
{{ end }}
