<div class="preheader">{{inviterName}} vous invite à rejoindre {{workspaceName}} sur {{company}}.</div>
<table role="presentation" class="email-wrapper" width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td align="center">
      <table role="presentation" class="email-container" width="600" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td class="email-header">
            <h1>Vous êtes invité</h1>
            <p>Rejoignez votre équipe sur {{company}}</p>
          </td>
        </tr>
        <tr>
          <td class="email-body">
            <h2>Bonjour {{name}},</h2>
            <p><strong>{{inviterName}}</strong> vous a invité à rejoindre l'espace de travail <strong>{{workspaceName}}</strong> sur {{company}} en tant que <strong>{{role}}</strong>.</p>
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin: 8px auto 24px;">
              <tr>
                <td align="center" bgcolor="#7e22ce" style="border-radius: 8px;">
                  <a href="{{acceptLink}}" class="btn" target="_blank">Accepter l'invitation</a>
                </td>
              </tr>
            </table>
            <div class="info-box">Cette invitation expire dans <strong>{{expiry}}</strong>. Si le bouton ne fonctionne pas, copiez et collez cette URL dans votre navigateur :<br/><a href="{{acceptLink}}">{{acceptLink}}</a></div>
            <p>Si vous n'attendiez pas cette invitation, vous pouvez ignorer cet email en toute sécurité.</p>
            <p>Cordialement,<br/>L'équipe {{company}}</p>
          </td>
        </tr>
        <tr>
          <td class="email-footer">
            <p>© {{year}} {{company}}</p>
            <p><a href="{{ posta_web_view_url }}">Afficher cet e-mail dans votre navigateur</a></p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>