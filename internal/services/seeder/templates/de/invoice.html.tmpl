<div class="preheader">Beleg für Rechnung {{invoiceNumber}} — {{total}}.</div>
<table role="presentation" class="email-wrapper" width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td align="center">
      <table role="presentation" class="email-container" width="600" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td class="email-header">
            <h1>Zahlungsbeleg</h1>
            <p>Rechnung {{invoiceNumber}}</p>
          </td>
        </tr>
        <tr>
          <td class="email-body">
            <h2>Hallo {{name}},</h2>
            <p>Vielen Dank für Ihre Zahlung. Dies ist Ihr Beleg für die Rechnung <strong>{{invoiceNumber}}</strong>, ausgestellt am {{invoiceDate}}.</p>
            <table class="data-table" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <th>Beschreibung</th>
                <th style="text-align:center;">Menge</th>
                <th style="text-align:right;">Betrag</th>
              </tr>
              {{range items}}
              <tr>
                <td>{{.name}}</td>
                <td style="text-align:center;">{{.qty}}</td>
                <td style="text-align:right;">{{.price}}</td>
              </tr>
              {{end}}
              <tr>
                <td colspan="2" style="text-align:right;">Zwischensumme</td>
                <td style="text-align:right;">{{subtotal}}</td>
              </tr>
              <tr>
                <td colspan="2" style="text-align:right;">Steuer</td>
                <td style="text-align:right;">{{tax}}</td>
              </tr>
              <tr>
                <td class="total-label" colspan="2" style="text-align:right;">Gesamt bezahlt</td>
                <td class="total-value">{{total}}</td>
              </tr>
            </table>
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin: 8px auto 24px;">
              <tr>
                <td align="center" style="border-radius: 8px;">
                  <a href="{{invoiceUrl}}" class="btn-secondary" target="_blank">Rechnung herunterladen (PDF)</a>
                </td>
              </tr>
            </table>
            <p>Mit freundlichen Grüßen,<br/>Das {{company}}-Team</p>
          </td>
        </tr>
        <tr>
          <td class="email-footer">
            <p>© {{year}} {{company}}</p>
            <p><a href="{{ posta_web_view_url }}">Diese E-Mail im Browser anzeigen</a></p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>