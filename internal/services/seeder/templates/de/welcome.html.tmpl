<div class="preheader">Ihr {{product}}-Konto ist bereit — versenden Sie E-Mails in wenigen Minuten.</div>
<table role="presentation" class="email-wrapper" width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td align="center">
      <table role="presentation" class="email-container" width="600" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td class="email-header">
            <h1>Willkommen bei Posta</h1>
            <p>Ihre selbst-gehostete E-Mail-Zustellplattform</p>
          </td>
        </tr>
        <tr>
          <td class="email-body">
            <h2>Hallo {{name}},</h2>
            <p>Willkommen bei <strong>{{product}}</strong>. Ihr Konto ist bereit und Sie können sofort E-Mails versenden.</p>
            <p>{{product}} bietet folgende Funktionen:</p>
            <ul class="feature-list">
              {{range features}}
              <li>{{.}}</li>
              {{end}}
            </ul>
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin: 8px auto 24px;">
              <tr>
                <td align="center" bgcolor="#7e22ce" style="border-radius: 8px;">
                  <a href="{{docs}}" class="btn" target="_blank">API-Dokumentation ansehen</a>
                </td>
              </tr>
            </table>
            <p class="muted">Hilfreiche Ressourcen:</p>
            <ul>
              {{range links}}
              <li><a href="{{.url}}">{{.title}}</a></li>
              {{end}}
            </ul>
            <p>Mit freundlichen Grüßen,<br/>Das {{company}}-Team</p>
          </td>
        </tr>
        <tr>
          <td class="email-footer">
            <p>© {{year}} {{company}} — Lizenziert unter Apache 2.0</p>
            <p><a href="{{ posta_web_view_url }}">Diese E-Mail im Browser anzeigen</a></p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>