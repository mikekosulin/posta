<div class="preheader">Die Highlights von {{month}} von {{company}}.</div>
<table role="presentation" class="email-wrapper" width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td align="center">
      <table role="presentation" class="email-container" width="600" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td class="email-header">
            <h1>Newsletter {{month}}</h1>
            <p>Die neuesten Updates von {{company}}</p>
          </td>
        </tr>
        <tr>
          <td class="email-body">
            <h2>Hallo {{name}},</h2>
            <p>Hier sind die Highlights dieses Monats:</p>
            {{range articles}}
            <div style="margin: 24px 0; padding-bottom: 20px; border-bottom: 1px solid #e5e7eb;">
              <h3 style="margin: 0 0 8px; color: #111827; font-size: 18px;">{{.title}}</h3>
              <p style="margin: 0 0 12px; color: #4b5563;">{{.summary}}</p>
              <a href="{{.url}}" style="color: #7c3aed; font-weight: 600; text-decoration: none;">Weiterlesen →</a>
            </div>
            {{end}}
            <p>Mit freundlichen Grüßen,<br/>Das {{company}}-Team</p>
          </td>
        </tr>
        <tr>
          <td class="email-footer">
            <p>© {{year}} {{company}}</p>
            <p><a href="{{ posta_web_view_url }}">Diese E-Mail im Browser anzeigen</a></p>
            <p><a href="{{unsubscribeUrl}}">Abmelden</a></p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>